    "MODEL_PATH = kagglehub.model_download(\"metric/nemotron-3-nano-30b-a3b-bf16/transformers/default\")\n",
    "\n",
    "# Auto-detect data paths\n",
    "_CANDIDATES = [\n",
    "    '/kaggle/input/prog-cot-training-data',\n",
    "    '/kaggle/input/datasets/hastws/prog-cot-training-data',\n",
    "    '/kaggle/input/datasets/hastws/prog-cot-training-data/versions/default',\n",
    "]\n",
    "COT_DATA = None\n",
    "for _c in _CANDIDATES:\n",
    "    if os.path.isdir(_c):\n",
    "        COT_DATA = _c\n",
    "        break\n",
    "if COT_DATA is None:\n",
    "    import glob as _glob\n",
    "    hits = _glob.glob('/kaggle/input/**/sft_difficulty_aware.csv', recursive=True)\n",
    "    if hits:\n",
    "        COT_DATA = os.path.dirname(hits[0])\n",
    "    else:\n",
    "        for root, dirs, files in os.walk('/kaggle/input'):\n",
    "            if files:\n",
    "                print(f\"  {root}: {files[:5]}\")\n",
    "            if root.count(os.sep) > 5:\n",
    "                break\n",
    "        raise FileNotFoundError(\"Cannot find sft_difficulty_aware.csv under /kaggle/input/\")\n",
    "print(f\"COT_DATA = {COT_DATA}\")\n",
    "print(f\"  Files: {os.listdir(COT_DATA)[:10]}\")\n",
    "\n",
    "# Load the difficulty-aware dataset\n",
    "train_df = pl.read_csv(f'{COT_DATA}/sft_difficulty_aware.csv')\n",
    "\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"  Loaded: sft_difficulty_aware.csv — {len(train_df)} rows\")\n",
    "print(f\"{'='*60}\")\n",
    "\n",
    "# Statistics\n",
    "pdf = train_df.to_pandas()\n",
    "print(f\"\\n  Mode distribution:\")\n",
    "for mode, cnt in pdf['mode'].value_counts().items():\n",
