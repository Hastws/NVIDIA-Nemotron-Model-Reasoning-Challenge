    "LORA_DROPOUT     = 0.05\n",
    "\n",
    "# =============================================\n",
    "#  🔴 OFFICIAL PROMPT SUFFIX — DO NOT MODIFY\n",
    "# =============================================\n",
    "PROMPT_SUFFIX = '\\nPlease put your final answer inside `\\\\boxed{}`. For example: `\\\\boxed{your answer}`'\n",
    "\n",
    "OUTPUT_DIR = \"/kaggle/working/adapter\"\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "print(f\"Stage 1: n={STAGE1_N_SAMPLES}, LR={STAGE1_LR}, epochs={STAGE1_EPOCHS}\")\n",
    "print(f\"Stage 1: max_seq={STAGE1_MAX_SEQ}, packing={STAGE1_PACKING}\")\n",
    "print(f\"Weighted loss: {USE_WEIGHTED_LOSS}\")\n",
    "print(f\"Stage 2: enabled={STAGE2_ENABLED}, n={STAGE2_N_SAMPLES}, LR={STAGE2_LR}\")\n",
    "print(f\"LoRA: rank={LORA_RANK}, alpha={LORA_ALPHA}, dropout={LORA_DROPOUT}\")\n",
    "print(f\"Prompt suffix: {repr(PROMPT_SUFFIX)}\")\n"
   ]
  },
