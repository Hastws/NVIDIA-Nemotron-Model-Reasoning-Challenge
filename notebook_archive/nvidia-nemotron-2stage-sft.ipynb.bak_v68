    "# --- Stage 1: Difficulty-aware training (all 9500 rows) ---\n",
    "STAGE1_N_SAMPLES = None     # None = use all rows\n",
    "STAGE1_LR        = 2e-5     # Low LR: 9500 samples (16x more than E1's 600)\n",
    "STAGE1_EPOCHS    = 1\n",
    "STAGE1_MAX_SEQ   = 512     # compact max=149tok, full_cot max=428tok\n",
    "STAGE1_BATCH     = 1\n",
    "STAGE1_GRAD_ACCUM = 4\n",
    "STAGE1_PACKING   = False    # Packing incompatible with custom loss_weights\n",
