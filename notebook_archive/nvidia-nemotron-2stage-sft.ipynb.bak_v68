    "# --- Weighted loss control ---\n",
    "USE_WEIGHTED_LOSS = True    # True = per-token loss weighting, False = standard boxed-only loss\n",
    "\n",
    "# --- Stage 2: Format polish (answer-only, low LR) ---\n",
    "STAGE2_ENABLED   = True\n",
    "STAGE2_N_SAMPLES = 600\n",
    "STAGE2_LR        = 4e-5    # Standard E1-like LR for short format stage\n",
    "STAGE2_EPOCHS    = 1\n",
    "STAGE2_MAX_SEQ   = 512\n",
    "STAGE2_BATCH     = 1\n",
    "STAGE2_GRAD_ACCUM = 4\n",
    "STAGE2_PACKING   = False\n",
    "\n",
    "# --- LoRA ---\n",
    "LORA_RANK        = 32\n",
