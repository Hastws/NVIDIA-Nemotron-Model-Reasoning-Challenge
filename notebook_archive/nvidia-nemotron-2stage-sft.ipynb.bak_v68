   "outputs": [],
   "source": [
    "# Load model (mamba_ssm is pre-installed in standard Kaggle image)\n",
    "t0 = time.time()\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_PATH,\n",
    "    device_map=\"auto\",\n",
    "    trust_remote_code=True,\n",
    "    dtype=torch.bfloat16,\n",
    ")\n",
    "print(f\"Model loaded in {time.time()-t0:.1f}s. Vocab size: {len(tokenizer)}\")\n",
    "\n",
    "# Ensure fast path is disabled (Blackwell compatibility)\n",
    "for name, mod in sys.modules.items():\n",
    "    if \"modeling_nemotron_h\" in name and hasattr(mod, 'is_fast_path_available'):\n",
    "        mod.is_fast_path_available = False\n",
    "\n",
    "# Re-patch causal_conv1d after model load (model may re-import modules)\n",
    "for mod_name, mod in list(sys.modules.items()):\n",
    "    if hasattr(mod, 'causal_conv1d_fn'):\n",
    "        mod.causal_conv1d_fn = causal_conv1d_fn_pure\n",
    "    if hasattr(mod, 'causal_conv1d_update'):\n",
    "        mod.causal_conv1d_update = causal_conv1d_update_pure\n",
    "\n",
    "# Setup LoRA\n",
    "lora_config = LoraConfig(\n",
    "    r=LORA_RANK,\n",
    "    lora_alpha=LORA_ALPHA,\n",
    "    target_modules=\"all-linear\",\n",
    "    lora_dropout=LORA_DROPOUT,\n",
    "    bias=\"none\",\n",
    "    task_type=TaskType.CAUSAL_LM,\n",
    ")\n",
    "\n",
    "model = get_peft_model(model, lora_config)\n",
    "model.print_trainable_parameters()\n",
    "\n",
    "# Log model architecture summary\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f\"\\nTotal params: {total_params/1e9:.2f}B\")\n",
    "print(f\"Trainable params: {trainable_params/1e6:.1f}M ({trainable_params/total_params*100:.2f}%)\")"
   ]
