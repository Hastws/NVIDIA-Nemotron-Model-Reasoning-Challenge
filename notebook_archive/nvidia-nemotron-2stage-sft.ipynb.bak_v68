   "source": [
    "# Difficulty-Aware SFT: Implicit Policy Routing\n",
    "\n",
    "**Strategy: 让模型学会\"何时思考\"**\n",
    "- **Easy problems** (numeral, gravity) → answer only, no thinking\n",
    "- **Medium problems** (unit_conv, cipher) → compact rules in `<think>`\n",
    "- **Hard problems** (bit_ops, symbol) → detailed CoT in `<think>`\n",
    "\n",
    "**Weighted Loss:** answer tokens = 1.0, compact thinking = 0.10, full CoT thinking = 0.05\n",
    "\n",
    "**2-Stage Training:**\n",
    "- **Stage 1**: ALL 9500 rows with weighted loss → learn reasoning routing\n",
    "- **Stage 2**: 600 answer-only rows → polish `\\boxed{}` format\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "da77ecbc",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, os, glob\n",
    "\n",
    "# Install trl + datasets from our own offline packages\n",
    "TARGET_DIR = \"/tmp/pip_pkgs\"\n",
    "offline_dir = \"/kaggle/input/sft-offline-packages\"\n",
    "\n",
    "if os.path.isdir(offline_dir):\n",
    "    whls = sorted(glob.glob(os.path.join(offline_dir, \"*.whl\")))\n",
    "    print(f\"Found {len(whls)} wheels in {offline_dir}\")\n",
    "    if whls:\n",
    "        result = subprocess.run(\n",
    "            [sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"--no-deps\",\n",
    "             \"--target\", TARGET_DIR, \"--ignore-installed\"] + whls,\n",
    "            capture_output=True, text=True, timeout=180\n",
    "        )\n",
    "        if result.returncode != 0:\n",
    "            print(f\"STDERR: {result.stderr[-500:]}\")\n",
    "            print(\"Warning: offline install failed, trying pre-installed packages\")\n",
    "        else:\n",
    "            sys.path.insert(0, TARGET_DIR)\n",
    "            print(f\"Installed to {TARGET_DIR}\")\n",
    "    else:\n",
    "        print(\"No .whl files found in offline dir\")\n",
    "else:\n",
    "    print(f\"{offline_dir} not found — using pre-installed packages\")\n",
    "\n",
    "# Verify core packages\n",
    "import importlib\n",
    "for pkg in [\"trl\", \"datasets\", \"torch\", \"transformers\", \"peft\"]:\n",
    "    mod = importlib.import_module(pkg)\n",
    "    print(f\"  {pkg}={getattr(mod, '__version__', '?')}\")\n",
    "print(\"All packages ready\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7f6106d5",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import stat\n",
    "import shutil\n",
    "import gc\n",
    "import zipfile\n",
    "import time\n",
    "import json\n",
    "import math\n",
    "import types\n",
    "import importlib\n",
    "import importlib.abc\n",
    "import importlib.machinery\n",
    "import polars as pl\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import kagglehub\n",
    "\n",
    "# =================================================================\n",
    "# Auto-mock import hook for mamba_ssm submodules that need\n",
    "# cutlass/tilelang (unavailable on Blackwell). Uses find_spec API\n",
    "# (find_module is deprecated in Python 3.12+).\n",
    "# =================================================================\n",
    "class _MockLoader(importlib.abc.Loader):\n",
    "    def create_module(self, spec):\n",
    "        mod = types.ModuleType(spec.name)\n",
    "        mod.__path__ = []  # package so sub-imports work\n",
    "        mod.__package__ = spec.name\n",
    "        mod.__loader__ = self\n",
    "        mod.__spec__ = spec\n",
    "        return mod\n",
    "    def exec_module(self, module):\n",
    "        pass  # nothing to execute\n",
    "\n",
    "class MambaMockFinder(importlib.abc.MetaPathFinder):\n",
    "    _MOCK_PREFIXES = (\n",
    "        \"mamba_ssm.ops.cute\",\n",
    "        \"mamba_ssm.ops.tilelang\",\n",
    "        \"mamba_ssm.ops.triton.mamba3\",\n",
    "        \"mamba_ssm.modules.mamba3\",\n",
    "    )\n",
    "    _loader = _MockLoader()\n",
    "\n",
    "    def find_spec(self, fullname, path, target=None):\n",
    "        for prefix in self._MOCK_PREFIXES:\n",
    "            if fullname == prefix or fullname.startswith(prefix + \".\"):\n",
    "                return importlib.machinery.ModuleSpec(\n",
    "                    fullname, self._loader,\n",
    "                    is_package=True,\n",
    "                    origin=\"mamba-mock\",\n",
    "                )\n",
    "        return None\n",
    "\n",
    "sys.meta_path.insert(0, MambaMockFinder())\n",
    "\n",
    "import mamba_ssm\n",
    "print(f\"mamba_ssm loaded (Mamba3/CUTE/tilelang mocked)\")\n",
    "\n",
    "from datasets import Dataset\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "from peft import LoraConfig, get_peft_model, TaskType\n",
    "from trl import SFTTrainer, SFTConfig\n",
    "\n",
    "print(f\"torch: {torch.__version__}, CUDA: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    props = torch.cuda.get_device_properties(0)\n",
    "    mem = getattr(props, 'total_memory', None) or getattr(props, 'total_mem', 0)\n",
    "    print(f\"GPU memory: {mem / 1024**3:.1f} GB\")\n",
    "    print(f\"CUDA capability: {props.major}.{props.minor}\")\n",
    "\n",
    "# ===================================================================\n",
    "# Blackwell compatibility patches (RTX Pro 6000 = SM 100)\n",
    "# ===================================================================\n",
    "\n",
    "# --- 1. Triton ptxas-blackwell fix ---\n",
    "SRC_PTXAS = \"/kaggle/usr/lib/notebooks/ryanholbrook/nvidia-utility-script/triton/backends/nvidia/bin/ptxas-blackwell\"\n",
    "if os.path.exists(SRC_PTXAS):\n",
    "    import triton.backends.nvidia.compiler as nv_compiler\n",
    "    DST = \"/kaggle/working/nvidia-utility-script\"\n",
    "    os.makedirs(f\"{DST}/triton/backends/nvidia/bin\", exist_ok=True)\n",
    "    dst_ptxas = f\"{DST}/triton/backends/nvidia/bin/ptxas-blackwell\"\n",
    "    shutil.copy2(SRC_PTXAS, dst_ptxas)\n",
    "    os.chmod(dst_ptxas, os.stat(dst_ptxas).st_mode | stat.S_IEXEC | stat.S_IXGRP | stat.S_IXOTH)\n",
    "\n",
    "    class FixedNvidiaTool:\n",
    "        def __init__(self, path, version=\"12.8\"):\n",
    "            self.path = path\n",
    "            self.version = version\n",
    "\n",
    "    _original_get_ptxas = nv_compiler.get_ptxas\n",
    "    def patched_get_ptxas(arch):\n",
    "        if arch >= 100:\n",
    "            return FixedNvidiaTool(dst_ptxas)\n",
    "        return _original_get_ptxas(arch)\n",
    "    nv_compiler.get_ptxas = patched_get_ptxas\n",
    "    print(\"Triton ptxas-blackwell patched\")\n",
    "else:\n",
    "    print(\"ptxas-blackwell not found, skipping Triton patch\")\n",
    "\n",
    "# --- 2. Disable CUDA fast path ---\n",
    "for mod_name, mod in list(sys.modules.items()):\n",
    "    if 'modeling_nemotron_h' in mod_name and hasattr(mod, 'is_fast_path_available'):\n",
    "        mod.is_fast_path_available = False\n",
    "        print(f\"Disabled fast path in {mod_name}\")\n",
    "\n",
    "# --- 3. Pure PyTorch causal_conv1d replacement ---\n",
    "def causal_conv1d_fn_pure(x, weight, bias=None, seq_idx=None, initial_states=None,\n",
    "                          return_final_states=False, final_states_out=None, activation=None):\n",
    "    dtype_in = x.dtype\n",
    "    x = x.to(weight.dtype)\n",
    "    seqlen = x.shape[-1]\n",
    "    dim, width = weight.shape\n",
    "    if initial_states is None:\n",
    "        out = F.conv1d(x, weight.unsqueeze(1), bias, padding=width - 1, groups=dim)\n",
    "    else:\n",
    "        x = torch.cat([initial_states, x], dim=-1)\n",
    "        out = F.conv1d(x, weight.unsqueeze(1), bias, padding=0, groups=dim)\n",
    "    out = out[..., :seqlen]\n",
    "    if activation in (\"silu\", \"swish\"):\n",
    "        out = F.silu(out)\n",
    "    out = out.to(dtype=dtype_in)\n",
    "    if return_final_states:\n",
    "        return out, x[..., -width + 1:].to(dtype_in)\n",
    "    return out\n",
    "\n",
    "def causal_conv1d_update_pure(x, conv_state, weight, bias=None, activation=None, cache_seqlens=None):\n",
    "    dtype_in = x.dtype\n",
    "    unsqueeze = x.dim() == 2\n",
    "    if unsqueeze:\n",
    "        x = x.unsqueeze(-1)\n",
    "    batch, dim, width = conv_state.shape\n",
    "    seqlen = x.shape[-1]\n",
    "    if cache_seqlens is not None:\n",
    "        for i in range(batch):\n",
    "            cs = cache_seqlens[i].item()\n",
    "            roll = max(0, cs + seqlen - (width - 1))\n",
    "            if roll > 0:\n",
    "                conv_state[i] = torch.roll(conv_state[i], shifts=-roll, dims=-1)\n",
    "            start = max(0, width - 1 - cs)\n",
    "            conv_state[i, :, start:start + seqlen] = x[i]\n",
    "    else:\n",
    "        conv_state.copy_(torch.roll(conv_state, shifts=-seqlen, dims=-1))\n",
    "        conv_state[:, :, -seqlen:] = x\n",
    "    state_plus_x = conv_state\n",
    "    out = (state_plus_x * weight.unsqueeze(0).flip(-1)).sum(dim=-1)\n",
    "    if bias is not None:\n",
    "        out = out + bias\n",
    "    if activation in (\"silu\", \"swish\"):\n",
    "        out = F.silu(out)\n",
    "    out = out.to(dtype_in)\n",
    "    if unsqueeze:\n",
    "        return out\n",
    "    return out.unsqueeze(-1)\n",
    "\n",
    "# Monkey-patch causal_conv1d everywhere\n",
    "try:\n",
    "    import causal_conv1d\n",
    "    causal_conv1d.causal_conv1d_fn = causal_conv1d_fn_pure\n",
    "    causal_conv1d.causal_conv1d_update = causal_conv1d_update_pure\n",
    "    print(\"Patched causal_conv1d with pure PyTorch ops\")\n",
    "except ImportError:\n",
    "    pass\n",
    "\n",
    "for mod_name, mod in list(sys.modules.items()):\n",
    "    if hasattr(mod, 'causal_conv1d_fn'):\n",
    "        mod.causal_conv1d_fn = causal_conv1d_fn_pure\n",
    "    if hasattr(mod, 'causal_conv1d_update'):\n",
    "        mod.causal_conv1d_update = causal_conv1d_update_pure\n",
    "\n",
    "# --- 4. Pure PyTorch rmsnorm replacement ---\n",
    "def _pure_rmsnorm_fn(x, weight, bias=None, z=None, eps=1e-5,\n",
    "                     group_size=None, norm_before_gate=True, upcast=True):\n",
    "    dtype = x.dtype\n",
    "    if upcast:\n",
    "        x = x.float()\n",
    "    variance = x.pow(2).mean(-1, keepdim=True)\n",
    "    x_normed = x * torch.rsqrt(variance + eps)\n",
    "    out = x_normed * weight.float()\n",
    "    if bias is not None:\n",
    "        out = out + bias.float()\n",
    "    if z is not None:\n",
    "        out = out * F.silu(z.float())\n",
    "    return out.to(dtype)\n",
    "\n",
    "for name, mod in list(sys.modules.items()):\n",
    "    if hasattr(mod, 'rmsnorm_fn'):\n",
    "        mod.rmsnorm_fn = _pure_rmsnorm_fn\n",
    "\n",
    "print(\"Imports and Blackwell patches ready\")"
   ]
  },
