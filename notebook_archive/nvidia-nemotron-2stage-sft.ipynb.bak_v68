  {
   "cell_type": "markdown",
   "id": "9c99f562",
   "metadata": {},
   "source": [
    "## Stage 1: Difficulty-Aware Training\n",
    "\n",
    "**9500 rows, weighted loss.** The model learns:\n",
    "- Easy problems → produce `\\boxed{answer}` directly  \n",
    "- Medium problems → brief compact reasoning → `\\boxed{answer}`\n",
    "- Hard problems → detailed CoT → `\\boxed{answer}`\n",
    "\n",
    "Answer tokens always get full loss weight (1.0). Thinking tokens get reduced weight (0.05-0.10) to avoid overwhelming the training signal.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d800938",
   "metadata": {},
   "outputs": [],
   "source": [
    "import triton.backends.nvidia.compiler as nv_compiler\n",
    "os.environ[\"TRITON_PTXAS_BLACKWELL_PATH\"] = \"/tmp/ptxas-blackwell\"\n",
    "nv_compiler.get_ptxas_version = lambda arch: \"12.0\"\n",
    "\n",
    "from torch.nn import CrossEntropyLoss\n",
    "from transformers import DataCollatorForSeq2Seq\n",
    "\n",
    "# =============================================\n",
    "#  Custom Data Collator (pads loss_weights)\n",
    "# =============================================\n",
    "class WeightedDataCollator(DataCollatorForSeq2Seq):\n",
    "    \"\"\"Extends DataCollatorForSeq2Seq to also pad loss_weights.\"\"\"\n",
    "    \n",
    "    def __call__(self, features, return_tensors=None):\n",
    "        # Extract loss_weights before standard collation\n",
    "        has_weights = \"loss_weights\" in features[0]\n",
    "        loss_weights_list = None\n",
    "        if has_weights:\n",
    "            loss_weights_list = [f.pop(\"loss_weights\") for f in features]\n",
    "        \n",
    "        # Standard collation for input_ids, labels, attention_mask\n",
    "        batch = super().__call__(features, return_tensors=return_tensors)\n",
    "        \n",
    "        # Pad loss_weights to match input_ids shape\n",
    "        if loss_weights_list is not None:\n",
    "            max_len = batch[\"input_ids\"].shape[1]\n",
    "            padded = []\n",
    "            for w in loss_weights_list:\n",
    "                pad_len = max_len - len(w)\n",
    "                padded.append(w + [0.0] * pad_len)\n",
    "            batch[\"loss_weights\"] = torch.tensor(padded, dtype=torch.float32)\n",
    "        \n",
    "        return batch\n",
    "\n",
    "# =============================================\n",
    "#  Custom Trainer (weighted per-token loss)\n",
    "# =============================================\n",
    "class WeightedSFTTrainer(SFTTrainer):\n",
    "    \"\"\"SFTTrainer with per-token loss weighting.\"\"\"\n",
    "    \n",
    "    def compute_loss(self, model, inputs, return_outputs=False, **kwargs):\n",
    "        loss_weights = inputs.pop(\"loss_weights\", None)\n",
    "        \n",
    "        if not USE_WEIGHTED_LOSS or loss_weights is None:\n",
    "            # Fallback to standard loss\n",
    "            outputs = model(**inputs)\n",
    "            return (outputs.loss, outputs) if return_outputs else outputs.loss\n",
    "        \n",
    "        outputs = model(**inputs)\n",
    "        logits = outputs.logits\n",
    "        labels = inputs[\"labels\"]\n",
    "        \n",
    "        # Shift for causal LM: predict next token\n",
    "        shift_logits = logits[..., :-1, :].contiguous()\n",
    "        shift_labels = labels[..., 1:].contiguous()\n",
    "        shift_weights = loss_weights[..., 1:].contiguous()\n",
    "        \n",
    "        # Per-token cross entropy (ignore_index=-100 handles padding)\n",
    "        loss_fct = CrossEntropyLoss(reduction='none', ignore_index=-100)\n",
    "        flat_logits = shift_logits.view(-1, shift_logits.size(-1))\n",
    "        flat_labels = shift_labels.view(-1)\n",
    "        flat_weights = shift_weights.view(-1)\n",
    "        \n",
    "        per_token_loss = loss_fct(flat_logits, flat_labels)\n",
    "        \n",
    "        # Apply weights\n",
    "        weighted_loss = per_token_loss * flat_weights\n",
    "        \n",
    "        # Average over tokens with positive weight\n",
    "        n_tokens = (flat_weights > 0).sum().clamp(min=1)\n",
    "        loss = weighted_loss.sum() / n_tokens\n",
    "        \n",
    "        return (loss, outputs) if return_outputs else loss\n",
    "\n",
    "# =============================================\n",
    "#  Stage 1 Training\n",
    "# =============================================\n",
    "eff_batch = STAGE1_BATCH * STAGE1_GRAD_ACCUM\n",
    "total_steps = (len(hf_dataset) // eff_batch) * STAGE1_EPOCHS\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"  STAGE 1: Difficulty-Aware Training\")\n",
    "print(f\"  Samples: {len(hf_dataset)}, LR: {STAGE1_LR}, Epochs: {STAGE1_EPOCHS}\")\n",
    "print(f\"  Max Seq: {STAGE1_MAX_SEQ}, Effective batch: {eff_batch}\")\n",
    "print(f\"  Weighted loss: {USE_WEIGHTED_LOSS}\")\n",
    "print(f\"  Estimated steps: ~{total_steps}\")\n",
    "print(f\"{'='*60}\")\n",
    "\n",
    "stage1_args = SFTConfig(\n",
    "    output_dir=OUTPUT_DIR,\n",
    "    per_device_train_batch_size=STAGE1_BATCH,\n",
    "    gradient_accumulation_steps=STAGE1_GRAD_ACCUM,\n",
    "    num_train_epochs=STAGE1_EPOCHS,\n",
    "    learning_rate=STAGE1_LR,\n",
    "    logging_steps=10,\n",
    "    bf16=True,\n",
    "    max_grad_norm=1.0,\n",
    "    optim=\"adamw_torch\",\n",
    "    lr_scheduler_type=\"cosine\",\n",
    "    warmup_ratio=0.1,\n",
    "    save_strategy=\"no\",\n",
    "    report_to=\"none\",\n",
    "    max_length=STAGE1_MAX_SEQ,\n",
    "    packing=STAGE1_PACKING,\n",
    "    gradient_checkpointing=True,\n",
    "    gradient_checkpointing_kwargs={\"use_reentrant\": True},\n",
    "    dataset_kwargs={\"skip_prepare_dataset\": True},\n",
    ")\n",
    "\n",
    "TrainerClass = WeightedSFTTrainer if USE_WEIGHTED_LOSS else SFTTrainer\n",
    "\n",
    "stage1_trainer = TrainerClass(\n",
    "    model=model,\n",
    "    train_dataset=hf_dataset,\n",
    "    processing_class=tokenizer,\n",
    "    data_collator=WeightedDataCollator(\n",
    "        tokenizer=tokenizer,\n",
    "        padding=True,\n",
    "        pad_to_multiple_of=None,\n",
    "    ),\n",
    "    args=stage1_args,\n",
    ")\n",
    "\n",
    "t0 = time.time()\n",
    "stage1_result = stage1_trainer.train()\n",
    "stage1_time = time.time() - t0\n",
    "\n",
    "print(f\"\\n{'='*60}\")\n",
    "print(f\"  STAGE 1 COMPLETE\")\n",
    "print(f\"  Time: {stage1_time/60:.1f} min\")\n",
    "print(f\"  Final loss: {stage1_result.training_loss:.4f}\")\n",
    "print(f\"{'='*60}\")\n"
   ]
  },
