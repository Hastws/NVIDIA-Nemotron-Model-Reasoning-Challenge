    "\n",
    "print(f\"\\n  Type × Mode cross-table:\")\n",
    "ct = pd.crosstab(pdf['type'], pdf['mode'])\n",
    "print(ct.to_string())\n",
    "\n",
    "# Thinking length stats by mode\n",
    "print(f\"\\n  Thinking length by mode:\")\n",
    "for mode in ['compact', 'full_cot']:\n",
    "    lens = pdf.loc[pdf['mode'] == mode, 'thinking'].str.len()\n",
    "    print(f\"    {mode}: n={len(lens)}, avg={lens.mean():.0f}, max={lens.max()}\")\n"
   ]
