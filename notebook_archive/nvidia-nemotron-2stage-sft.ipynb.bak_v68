    "    print(f\"  LR: {STAGE2_LR}, Epochs: {STAGE2_EPOCHS}, Max Seq: {STAGE2_MAX_SEQ}\")\n",
    "    print(f\"  Estimated steps: ~{total_steps2}\")\n",
