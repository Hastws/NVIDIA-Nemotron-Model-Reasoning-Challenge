   "source": [
    "## Pre-tokenization with Weighted Loss\n",
    "\n",
    "**Token-level loss weights:**\n",
    "- Prompt tokens (user message) → label=-100, weight=0 (never train)\n",
    "- `<think>` tag tokens → label=-100, weight=0 (structural)\n",
    "- Thinking content tokens → weight = `think_loss_weight` (0.0 / 0.10 / 0.05)\n",
    "- `</think>` token → label=-100, weight=0\n",
    "- Answer tokens (`\\boxed{...}`) → weight = 1.0 (primary training signal)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f26704e4",
   "metadata": {},
   "outputs": [],
   "source": [
    "import math\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_PATH, trust_remote_code=True)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "# Special token IDs for boundary detection\n",
    "THINK_OPEN_ID = tokenizer.convert_tokens_to_ids(\"<think>\")\n",
    "THINK_CLOSE_ID = tokenizer.convert_tokens_to_ids(\"</think>\")\n",
    "print(f\"<think> token ID: {THINK_OPEN_ID}\")\n",
    "print(f\"</think> token ID: {THINK_CLOSE_ID}\")\n",
    "\n",
    "# Verify PROMPT_SUFFIX\n",
    "official_suffix = '\\nPlease put your final answer inside `\\\\boxed{}`. For example: `\\\\boxed{your answer}`'\n",
    "assert PROMPT_SUFFIX == official_suffix, f\"SUFFIX MISMATCH!\"\n",
    "print(\"✅ Prompt suffix matches official evaluation\")\n",
    "\n",
    "def _has_thinking(thinking):\n",
    "    \"\"\"Return True if thinking contains actual content.\"\"\"\n",
    "    if thinking is None:\n",
    "        return False\n",
    "    if isinstance(thinking, float) and math.isnan(thinking):\n",
    "        return False\n",
    "    s = str(thinking).strip()\n",
    "    return len(s) > 0 and s.lower() != 'nan'\n",
    "\n",
    "def build_training_example(example):\n",
    "    \"\"\"Pre-tokenize with labels and loss_weights for weighted loss.\n",
    "    \n",
    "    All examples use PROMPT_SUFFIX + \\\\boxed{} format (matches eval).\n",
    "    Thinking content goes in <think> tags with variable loss weight.\n",
    "    \"\"\"\n",
    "    prompt = example[\"prompt\"]\n",
    "    answer = str(example[\"answer\"])\n",
    "    thinking = example.get(\"thinking\", None)\n",
    "    think_weight = float(example.get(\"think_loss_weight\", 0.0))\n",
    "    \n",
    "    user_msg = prompt + PROMPT_SUFFIX\n",
    "    \n",
    "    if _has_thinking(thinking):\n",
    "        thinking_str = str(thinking).strip()\n",
    "        # Manual ChatML with thinking\n",
    "        text = (\n",
    "            f\"<|im_start|>user\\n{user_msg}<|im_end|>\\n\"\n",
    "            f\"<|im_start|>assistant\\n<think>\\n{thinking_str}\\n</think>\\n\\\\boxed{{{answer}}}<|im_end|>\"\n",
    "        )\n",
    "    else:\n",
    "        # Answer-only: use template with enable_thinking=True → adds <think></think>\n",
    "        assistant_msg = f\"\\\\boxed{{{answer}}}\"\n",
    "        messages = [\n",
    "            {\"role\": \"user\", \"content\": user_msg},\n",
    "            {\"role\": \"assistant\", \"content\": assistant_msg},\n",
    "        ]\n",
    "        text = tokenizer.apply_chat_template(\n",
    "            messages, tokenize=False, add_generation_prompt=False,\n",
    "            enable_thinking=True,\n",
    "        )\n",
    "    \n",
    "    # Tokenize\n",
    "    input_ids = tokenizer.encode(text, add_special_tokens=False,\n",
    "                                  truncation=True, max_length=STAGE1_MAX_SEQ)\n",
    "    n = len(input_ids)\n",
    "    \n",
    "    # Find <think> and </think> positions\n",
    "    think_open_pos = None\n",
    "    think_close_pos = None\n",
    "    for i, tid in enumerate(input_ids):\n",
    "        if tid == THINK_OPEN_ID and think_open_pos is None:\n",
    "            think_open_pos = i\n",
    "        if tid == THINK_CLOSE_ID:\n",
    "            think_close_pos = i  # last </think>\n",
    "    \n",
    "    # Build labels and loss_weights\n",
    "    labels = [-100] * n\n",
    "    loss_weights = [0.0] * n\n",
    "    \n",
    "    if think_close_pos is not None:\n",
    "        # --- Thinking tokens: between <think> and </think> ---\n",
    "        if think_open_pos is not None and think_weight > 0:\n",
    "            # thinking content starts after <think> + newline, ends before </think>\n",
    "            for j in range(think_open_pos + 1, think_close_pos):\n",
    "                labels[j] = input_ids[j]\n",
    "                loss_weights[j] = think_weight\n",
    "        \n",
    "        # --- Answer tokens: everything after </think> ---\n",
    "        for j in range(think_close_pos + 1, n):\n",
    "            labels[j] = input_ids[j]\n",
    "            loss_weights[j] = 1.0\n",
    "    else:\n",
    "        # Safety fallback: no think token found, train on all tokens\n",
    "        labels = list(input_ids)\n",
    "        loss_weights = [1.0] * n\n",
    "    \n",
    "    return {\n",
    "        \"input_ids\": input_ids,\n",
    "        \"attention_mask\": [1] * n,\n",
    "        \"labels\": labels,\n",
    "        \"loss_weights\": loss_weights,\n",
    "    }\n",
    "\n",
    "# =============================================\n",
    "#  Stage 2 builder: standard boxed-only loss\n",
    "# =============================================\n",
    "def build_stage2_example(example):\n",
    "    \"\"\"Stage 2: answer-only with boxed-only loss (mask up to </think>).\"\"\"\n",
    "    prompt = example[\"prompt\"]\n",
    "    answer = str(example[\"answer\"])\n",
    "    user_msg = prompt + PROMPT_SUFFIX\n",
    "    \n",
    "    messages = [\n",
    "        {\"role\": \"user\", \"content\": user_msg},\n",
    "        {\"role\": \"assistant\", \"content\": f\"\\\\boxed{{{answer}}}\"},\n",
    "    ]\n",
    "    text = tokenizer.apply_chat_template(\n",
    "        messages, tokenize=False, add_generation_prompt=False,\n",
    "        enable_thinking=True,\n",
    "    )\n",
    "    \n",
    "    input_ids = tokenizer.encode(text, add_special_tokens=False,\n",
    "                                  truncation=True, max_length=STAGE2_MAX_SEQ)\n",
    "    n = len(input_ids)\n",
    "    \n",
    "    # Find </think> and mask everything before it\n",
    "    prefix_len = n  # default: mask all\n",
    "    for i, tid in enumerate(input_ids):\n",
    "        if tid == THINK_CLOSE_ID:\n",
    "            prefix_len = i + 1\n",
    "            break\n",
    "    \n",
    "    labels = [-100] * prefix_len + input_ids[prefix_len:]\n",
    "    # Stage 2 uses standard loss (no weighting needed)\n",
    "    loss_weights = [0.0] * prefix_len + [1.0] * (n - prefix_len)\n",
    "    \n",
    "    return {\n",
    "        \"input_ids\": input_ids,\n",
    "        \"attention_mask\": [1] * n,\n",
    "        \"labels\": labels,\n",
    "        \"loss_weights\": loss_weights,\n",
    "    }\n",
    "\n",
    "# =============================================\n",
    "#  Format verification\n",
    "# =============================================\n",
    "print(\"\\n=== FORMAT VERIFICATION ===\")\n",
    "sample_pdf = train_df.to_pandas()\n",
    "\n",
    "# Test each mode\n",
    "for mode in ['answer_only', 'compact', 'full_cot']:\n",
    "    rows = sample_pdf[sample_pdf['mode'] == mode]\n",
    "    if len(rows) == 0:\n",
    "        continue\n",
    "    row = rows.iloc[0].to_dict()\n",
    "    result = build_training_example(row)\n",
    "    n_loss = sum(1 for x in result['labels'] if x != -100)\n",
    "    n_weighted = sum(1 for w in result['loss_weights'] if w > 0)\n",
    "    max_w = max(result['loss_weights'])\n",
    "    min_w = min(w for w in result['loss_weights'] if w > 0) if n_weighted > 0 else 0\n",
    "    think_toks = sum(1 for w in result['loss_weights'] if 0 < w < 1.0)\n",
    "    answer_toks = sum(1 for w in result['loss_weights'] if w == 1.0)\n",
    "    print(f\"\\n--- {mode} (id={row['id']}) ---\")\n",
    "    print(f\"  Tokens: {len(result['input_ids'])}, Loss tokens: {n_loss}\")\n",
    "    print(f\"  Thinking tokens (weighted): {think_toks}, Answer tokens: {answer_toks}\")\n",
    "    print(f\"  Weight range: [{min_w}, {max_w}]\")\n",
    "    # Decode just the answer tokens\n",
    "    answer_text = tokenizer.decode([t for t, w in zip(result['input_ids'], result['loss_weights']) if w == 1.0])\n",
    "    print(f\"  Answer text: {answer_text[:100]}\")\n",
    "\n",
    "# Test Stage 2\n",
    "row = sample_pdf[sample_pdf['mode'] == 'answer_only'].iloc[0].to_dict()\n",
    "result2 = build_stage2_example(row)\n",
    "n_loss2 = sum(1 for x in result2['labels'] if x != -100)\n",
    "print(f\"\\n--- Stage 2 example ---\")\n",
    "print(f\"  Tokens: {len(result2['input_ids'])}, Loss tokens: {n_loss2}\")\n",
    "answer_text2 = tokenizer.decode([t for t in result2['labels'] if t != -100])\n",
    "print(f\"  Answer text: {answer_text2[:100]}\")\n",
    "\n",
    "print(\"\\n✅ All format checks passed!\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5805f7c8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare Stage 1 dataset (all rows with weighted loss)\n",
    "stage1_pdf = train_df.to_pandas()\n",
    "\n",
    "if STAGE1_N_SAMPLES is not None:\n",
    "    stage1_pdf = stage1_pdf.sample(n=min(STAGE1_N_SAMPLES, len(stage1_pdf)), random_state=42)\n",
    "    print(f\"Stage 1 subsampled: {len(stage1_pdf)} rows\")\n",
    "\n",
    "hf_dataset = Dataset.from_pandas(stage1_pdf)\n",
    "hf_dataset = hf_dataset.map(\n",
    "    build_training_example,\n",
    "    remove_columns=hf_dataset.column_names,\n",
    ")\n",
    "print(f\"Stage 1 dataset ready: {len(hf_dataset)} examples\")\n",
    "\n",
    "# Token and weight analysis\n",
    "import numpy as np\n",
    "\n",
    "token_lengths = np.array([len(x['input_ids']) for x in hf_dataset])\n",
    "loss_token_counts = np.array([sum(1 for l in x['labels'] if l != -100) for x in hf_dataset])\n",
    "think_token_counts = np.array([sum(1 for w in x['loss_weights'] if 0 < w < 1.0) for x in hf_dataset])\n",
    "answer_token_counts = np.array([sum(1 for w in x['loss_weights'] if w == 1.0) for x in hf_dataset])\n",
    "\n",
    "print(f\"\\n=== TOKEN LENGTH ANALYSIS ===\")\n",
    "print(f\"  Total samples: {len(token_lengths)}\")\n",
    "print(f\"  Token lengths:  min={token_lengths.min()}, median={np.median(token_lengths):.0f}, max={token_lengths.max()}\")\n",
    "print(f\"  Loss tokens:    min={loss_token_counts.min()}, median={np.median(loss_token_counts):.0f}, max={loss_token_counts.max()}\")\n",
    "print(f\"  Think tokens:   min={think_token_counts.min()}, median={np.median(think_token_counts):.0f}, max={think_token_counts.max()}\")\n",
    "print(f\"  Answer tokens:  min={answer_token_counts.min()}, median={np.median(answer_token_counts):.0f}, max={answer_token_counts.max()}\")\n",
    "\n",
    "# Effective loss weight per sample (sum of weights / count)\n",
    "eff_weights = [sum(x['loss_weights']) for x in hf_dataset]\n",
    "print(f\"\\n  Effective weight sum per sample: min={min(eff_weights):.1f}, avg={np.mean(eff_weights):.1f}, max={max(eff_weights):.1f}\")\n"
   ]
  },
