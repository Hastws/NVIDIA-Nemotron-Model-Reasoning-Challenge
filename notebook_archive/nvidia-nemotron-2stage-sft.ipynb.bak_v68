    "        warmup_ratio=0.1,\n",
    "        save_strategy=\"no\",\n",
    "        report_to=\"none\",\n",
    "        max_length=STAGE2_MAX_SEQ,\n",
    "        packing=STAGE2_PACKING,\n",
    "        gradient_checkpointing=True,\n",
    "        gradient_checkpointing_kwargs={\"use_reentrant\": True},\n",
    "        dataset_kwargs={\"skip_prepare_dataset\": True},\n",
    "    )\n",
    "    \n",
    "    # Use WeightedSFTTrainer for consistent handling (weights are 0/1 in stage2)\n",
    "    stage2_trainer = WeightedSFTTrainer(\n",
    "        model=model,  # Same model — continues from Stage 1\n",
    "        train_dataset=stage2_dataset,\n",
    "        processing_class=tokenizer,\n",
    "        data_collator=WeightedDataCollator(\n",
    "            tokenizer=tokenizer,\n",
    "            padding=True,\n",
    "            pad_to_multiple_of=None,\n",
    "        ),\n",
    "        args=stage2_args,\n",
